{
  "manifest_version": 3,
  "name": "Dark Mode for Chrome — Night & Eye Care",
  "short_name": "Dark Mode",
  "version": "1.0.1",
  "description": "Dark mode for Chrome with midnight black and black-and-white reading modes. Reduce glare and improve readability.",
  "default_locale": "en_US",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Dark Mode for Chrome"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
