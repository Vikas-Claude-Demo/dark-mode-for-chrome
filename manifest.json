{
  "manifest_version": 3,
  "name": "Dark Mode for Chrome — Night & Eye Care",
  "short_name": "Dark Mode",
  "version": "1.0.0",
  "description": "Dark mode, midnight black, and black & white reading modes for websites in Chrome. Improve readability, reduce eye strain, and schedule a more comfortable browsing experience.",
  "default_locale": "en_US",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Dark Mode for Chrome"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
