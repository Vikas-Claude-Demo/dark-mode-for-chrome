{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/privacy-policy",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/privacy-policy/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
